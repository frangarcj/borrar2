{
  "name": "node-hello",
  "version": "1.0.0",
  "description": "Simple Node.js Hello World for GH Actions testing",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "test": "jest",
    "test-jenkins": "jest --ci --reporters=default --reporters=jest-junit",
    "coverage-jenkins": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint:json": "eslint src/**/*.js --format json -o coverage/eslint-result.json"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3"
  },
  "jest-junit": {
    "outputDirectory": "./coverage",
    "outputName": "test.results.xml"
  }
}
